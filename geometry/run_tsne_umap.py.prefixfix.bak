#!/usr/bin/env python
# -*- coding: utf-8 -*-
"""
Geometry Script 2: t-SNE + UMAP for all 49 layers, all points.

Per config: 49 layers, 960 points each.
  t-SNE: 3 pages (20 subplots per page, 4×5 layout)
  UMAP:  3 pages (same layout, if umap-learn installed)

Output: geometry/outputs/tsne_umap_{exp}_{iter}.pdf

Estimated time: ~1-2h for exp2 (8 configs × 49 layers × ~15s/t-SNE).
Use sbatch on short partition.

Usage:
    python geometry/run_tsne_umap.py --exp exp2 --iter v7
    python geometry/run_tsne_umap.py --exp exp1a --iter v8
"""
import sys, os, argparse, time
import numpy as np
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
from matplotlib.backends.backend_pdf import PdfPages
from sklearn.manifold import TSNE

sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..'))
from config import EXP_CONFIG, CONFIG_MATRIX, config_label, MODEL_REGISTRY

try:
    from umap import UMAP
    HAS_UMAP = True
except ImportError:
    HAS_UMAP = False

BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
OUT_DIR = os.path.join(BASE_DIR, 'geometry', 'outputs')
os.makedirs(OUT_DIR, exist_ok=True)

CLASS_NAMES = {
    'exp1a': {0: 'Weekend', 1: 'Weekday'},
    'exp2':  {0: 'Unemployed', 1: 'Employed'},
}
ALL_LAYERS = list(range(49))
ROWS, COLS = 4, 5

np.random.seed(42)


def load_hidden(iter_name, exp, cfg_id):
    tag = MODEL_REGISTRY['12b']['tag']
    path = os.path.join(BASE_DIR, f'outputs_{iter_name}', 'hidden_states',
                        tag, f'{exp}_cfg{cfg_id}.npz')
    if not os.path.exists(path):
        return None, None
    d = np.load(path, allow_pickle=True)
    return d['hidden_states'], d['labels']


def direction_accuracy(X, y):
    c0, c1 = X[y == 0].mean(0), X[y == 1].mean(0)
    d = c1 - c0
    projs = X @ d
    thr = np.median(projs)
    preds = (projs > thr).astype(int)
    return ((preds[y == 0] == 0).mean() + (preds[y == 1] == 1).mean()) / 2


def embed_pages(pdf, X, y, exp, iter_name, cfg_id, method_name, embedder_fn):
    cn = CLASS_NAMES[exp]
    cl = config_label(exp, cfg_id)
    n_model_layers = X.shape[1]
    layers = [l for l in ALL_LAYERS if l < n_model_layers]
    per_page = ROWS * COLS

    for page_start in range(0, len(layers), per_page):
        page_layers = layers[page_start:page_start + per_page]
        n_plots = len(page_layers)
        nrows = min(ROWS, (n_plots + COLS - 1) // COLS)

        fig, axes = plt.subplots(nrows, COLS, figsize=(3.5 * COLS, 3.5 * nrows),
                                  squeeze=False)
        for idx, l in enumerate(page_layers):
            ax = axes[idx // COLS, idx % COLS]
            Xl = X[:, l, :]

            try:
                proj = embedder_fn(Xl)
            except Exception as e:
                ax.text(0.5, 0.5, f'Error:\n{e}', ha='center', va='center',
                        fontsize=6, transform=ax.transAxes)
                ax.set_title(f'L{l}', fontsize=7)
                continue

            for c in [0, 1]:
                mask = y == c
                ax.scatter(proj[mask, 0], proj[mask, 1], s=2, alpha=0.3,
                           label=cn[c] if idx == 0 else None)

            da = direction_accuracy(Xl, y)
            ax.set_title(f'L{l} (DA={da:.1%})', fontsize=7, fontweight='bold')
            ax.tick_params(labelsize=4)
            ax.set_xticks([]); ax.set_yticks([])

        for idx in range(n_plots, nrows * COLS):
            axes[idx // COLS, idx % COLS].set_visible(False)

        if page_start == 0:
            axes[0, 0].legend(fontsize=6, markerscale=4, loc='best')

        p = page_start // per_page + 1
        fig.suptitle(f'{method_name} — {iter_name.upper()}/{exp}/cfg{cfg_id} ({cl}) '
                     f'— Page {p}',
                     fontsize=11, fontweight='bold')
        plt.tight_layout(rect=[0, 0, 1, 0.95])
        pdf.savefig(fig, dpi=120); plt.close()


def tsne_embed(X):
    return TSNE(n_components=2, perplexity=30, random_state=42).fit_transform(X)


def umap_embed(X):
    return UMAP(n_components=2, n_neighbors=15, min_dist=0.1,
                random_state=42).fit_transform(X)


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument('--exp', required=True, choices=['exp1a', 'exp2'])
    parser.add_argument('--iter', required=True, choices=['v7', 'v8'])
    parser.add_argument('--model', default='12b',
                        choices=list(MODEL_REGISTRY.keys()),
                        help='Model key (default: 12b)')
    args = parser.parse_args()

    print(f"{'='*60}")
    print(f"t-SNE + UMAP: {args.iter}/{args.exp}")
    print(f"UMAP available: {HAS_UMAP}")
    print(f"{'='*60}")

    all_data = {}
    for cfg in CONFIG_MATRIX[args.exp]:
        cid = cfg['id']
        X, y = load_hidden(args.iter, args.exp, cid)
        if X is not None:
            all_data[cid] = (X, y)
            print(f"  cfg{cid}: {X.shape}")

    if not all_data:
        print("  No data found."); return

    out_path = os.path.join(OUT_DIR, f'tsne_umap_{args.exp}_{args.iter}.pdf')
    print(f"  Output: {out_path}")

    t0 = time.time()
    with PdfPages(out_path) as pdf:
        for cid in sorted(all_data):
            X, y = all_data[cid]

            print(f"  t-SNE cfg{cid} (49 layers × 960 pts)...")
            t1 = time.time()
            embed_pages(pdf, X, y, args.exp, args.iter, cid, 't-SNE', tsne_embed)
            print(f"    Done in {(time.time()-t1)/60:.1f} min")

            if HAS_UMAP:
                print(f"  UMAP cfg{cid}...")
                t1 = time.time()
                embed_pages(pdf, X, y, args.exp, args.iter, cid, 'UMAP', umap_embed)
                print(f"    Done in {(time.time()-t1)/60:.1f} min")

    print(f"\n  Total: {(time.time()-t0)/60:.1f} min")
    print(f"  Done → {out_path}")


if __name__ == "__main__":
    main()
