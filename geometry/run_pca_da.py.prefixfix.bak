#!/usr/bin/env python
# -*- coding: utf-8 -*-
"""
Geometry Script 1: PCA Scatter + Direction Accuracy + Normalized Separation.

Per config: PCA scatter for layers 20-48 (29 layers), all 960 points.
  Page layout: 4 rows × 5 cols = 20 subplots per page → 2 pages per config.
Then: 1 page DA curves (all configs), 1 page Sep curves.

Output: geometry/outputs/pca_da_{exp}_{iter}.pdf

Usage:
    python geometry/run_pca_da.py --exp exp2 --iter v7
    python geometry/run_pca_da.py --exp exp1a --iter v8
"""
import sys, os, argparse
import numpy as np
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
from matplotlib.backends.backend_pdf import PdfPages
from sklearn.decomposition import PCA

sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..'))
from config import EXP_CONFIG, CONFIG_MATRIX, config_label, MODEL_REGISTRY

BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
OUT_DIR = os.path.join(BASE_DIR, 'geometry', 'outputs')
os.makedirs(OUT_DIR, exist_ok=True)

CFG_COLORS = {1: '#1f77b4', 2: '#ff7f0e', 3: '#2ca02c', 4: '#d62728',
              5: '#9467bd', 6: '#8c564b', 7: '#e377c2', 8: '#7f7f7f'}
CLASS_NAMES = {
    'exp1a': {0: 'Weekend', 1: 'Weekday'},
    'exp2':  {0: 'Unemployed', 1: 'Employed'},
}
PCA_LAYERS = list(range(20, 49))  # layers 20-48 inclusive
ROWS, COLS = 4, 5


def load_hidden(iter_name, exp, cfg_id):
    tag = MODEL_REGISTRY['12b']['tag']
    path = os.path.join(BASE_DIR, f'outputs_{iter_name}', 'hidden_states',
                        tag, f'{exp}_cfg{cfg_id}.npz')
    if not os.path.exists(path):
        return None, None
    d = np.load(path, allow_pickle=True)
    return d['hidden_states'], d['labels']


def direction_accuracy(X, y):
    c0, c1 = X[y == 0].mean(0), X[y == 1].mean(0)
    d = c1 - c0
    projs = X @ d
    thr = np.median(projs)
    preds = (projs > thr).astype(int)
    return ((preds[y == 0] == 0).mean() + (preds[y == 1] == 1).mean()) / 2


def normalized_separation(X, y):
    c0, c1 = X[y == 0].mean(0), X[y == 1].mean(0)
    return np.linalg.norm(c1 - c0) / np.sqrt(X.shape[1])


def pca_pages(pdf, X, y, exp, iter_name, cfg_id):
    cn = CLASS_NAMES[exp]
    cl = config_label(exp, cfg_id)
    n_model_layers = X.shape[1]
    layers = [l for l in PCA_LAYERS if l < n_model_layers]
    per_page = ROWS * COLS

    for page_start in range(0, len(layers), per_page):
        page_layers = layers[page_start:page_start + per_page]
        n_plots = len(page_layers)
        nrows = min(ROWS, (n_plots + COLS - 1) // COLS)

        fig, axes = plt.subplots(nrows, COLS, figsize=(3.5 * COLS, 3.5 * nrows),
                                  squeeze=False)
        for idx, l in enumerate(page_layers):
            ax = axes[idx // COLS, idx % COLS]
            Xl = X[:, l, :]
            pca = PCA(n_components=2)
            proj = pca.fit_transform(Xl)
            ev = pca.explained_variance_ratio_
            ev = np.nan_to_num(ev, nan=0.0)

            for c in [0, 1]:
                mask = y == c
                ax.scatter(proj[mask, 0], proj[mask, 1], s=2, alpha=0.3,
                           label=cn[c] if idx == 0 else None)

            da = direction_accuracy(Xl, y)
            ax.set_title(f'L{l} (DA={da:.1%})', fontsize=7, fontweight='bold')
            ax.set_xlabel(f'PC1 ({ev[0]:.1%})', fontsize=5)
            ax.set_ylabel(f'PC2 ({ev[1]:.1%})', fontsize=5)
            ax.tick_params(labelsize=5)

        # Hide unused subplots
        for idx in range(n_plots, nrows * COLS):
            axes[idx // COLS, idx % COLS].set_visible(False)

        if page_start == 0:
            axes[0, 0].legend(fontsize=6, markerscale=4, loc='best')

        p = page_start // per_page + 1
        fig.suptitle(f'PCA — {iter_name.upper()}/{exp}/cfg{cfg_id} ({cl}) '
                     f'— Page {p}',
                     fontsize=11, fontweight='bold')
        plt.tight_layout(rect=[0, 0, 1, 0.95])
        pdf.savefig(fig, dpi=150); plt.close()


def da_page(pdf, all_data, exp, iter_name):
    fig, ax = plt.subplots(figsize=(14, 7))
    for cfg_id, (X, y) in sorted(all_data.items()):
        n_layers = X.shape[1]
        das = [direction_accuracy(X[:, l, :], y) for l in range(n_layers)]
        cl = config_label(exp, cfg_id)
        ax.plot(das, color=CFG_COLORS[cfg_id], lw=1.5, label=f'cfg{cfg_id} ({cl})')
    ax.set(xlabel='Layer', ylabel='Direction Accuracy', ylim=(0.45, 1.0))
    ax.axhline(0.5, color='gray', ls=':', alpha=0.3)
    ax.set_title(f'{EXP_CONFIG[exp]["name"]} — Direction Accuracy '
                 f'({iter_name.upper()}, all configs)',
                 fontweight='bold')
    ax.legend(fontsize=7, loc='upper left')
    ax.grid(True, alpha=0.1)
    plt.tight_layout(); pdf.savefig(fig, dpi=150); plt.close()


def sep_page(pdf, all_data, exp, iter_name):
    fig, ax = plt.subplots(figsize=(14, 7))
    for cfg_id, (X, y) in sorted(all_data.items()):
        n_layers = X.shape[1]
        seps = [normalized_separation(X[:, l, :], y) for l in range(n_layers)]
        cl = config_label(exp, cfg_id)
        ax.plot(seps, color=CFG_COLORS[cfg_id], lw=1.5, label=f'cfg{cfg_id} ({cl})')
    ax.set(xlabel='Layer', ylabel='Normalized Separation')
    ax.set_title(f'{EXP_CONFIG[exp]["name"]} — Normalized Separation '
                 f'({iter_name.upper()}, all configs)',
                 fontweight='bold')
    ax.legend(fontsize=7, loc='upper left')
    ax.grid(True, alpha=0.1)
    plt.tight_layout(); pdf.savefig(fig, dpi=150); plt.close()


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument('--exp', required=True, choices=['exp1a', 'exp2'])
    parser.add_argument('--iter', required=True, choices=['v7', 'v8'])
    parser.add_argument('--model', default='12b',
                        choices=list(MODEL_REGISTRY.keys()),
                        help='Model key (default: 12b)')
    args = parser.parse_args()

    print(f"{'='*60}")
    print(f"PCA + DA + Sep: {args.iter}/{args.exp}")
    print(f"{'='*60}")

    all_data = {}
    for cfg in CONFIG_MATRIX[args.exp]:
        cid = cfg['id']
        X, y = load_hidden(args.iter, args.exp, cid)
        if X is not None:
            all_data[cid] = (X, y)
            print(f"  cfg{cid}: {X.shape}")

    if not all_data:
        print("  No data found."); return

    out_path = os.path.join(OUT_DIR, f'pca_da_{args.exp}_{args.iter}.pdf')
    print(f"  Output: {out_path}")

    with PdfPages(out_path) as pdf:
        for cid in sorted(all_data):
            X, y = all_data[cid]
            print(f"  PCA cfg{cid}...")
            pca_pages(pdf, X, y, args.exp, args.iter, cid)

        print(f"  DA curves...")
        da_page(pdf, all_data, args.exp, args.iter)

        print(f"  Sep curves...")
        sep_page(pdf, all_data, args.exp, args.iter)

    print(f"  Done → {out_path}")


if __name__ == "__main__":
    main()
